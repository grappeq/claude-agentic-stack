{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(ssh sandbox *)",
      "Bash(ssh sandbox)",
      "Bash(rsync *)",
      "Bash(scp *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.netrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.ssh/**)",
      "Bash(sudo *)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(curl * | *)",
      "Bash(wget * | *)"
    ]
  },
  "env": {
    "SANDBOX_REMOTE_DIR": "~/agentic-workspace",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  }
}
