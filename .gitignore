node_modules/
dist/
build/
out/
target/
.venv/
venv/
__pycache__/
*.pyc
.gradle/
*.class

# Runtime evidence from the verify/e2e stage (screenshots, logs)
.agentic/

# Editor / OS noise
.DS_Store
.idea/
*.swp
